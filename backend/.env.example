# Aiven PostgreSQL — use the connection string from Aiven console.
# If you use a pooler, set DIRECT_DATABASE_URL to the non-pooler URL for migrations when needed.
DATABASE_URL="postgres://avnadmin:YOUR_PASSWORD@HOST:PORT/defaultdb?sslmode=require"
DIRECT_DATABASE_URL="postgres://avnadmin:YOUR_PASSWORD@HOST:PORT/defaultdb?sslmode=require"

BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
UPLOAD_BASE_URL="http://localhost:3001"
UPLOAD_DIR="./uploads"
PORT=3001
FRONTEND_URL="http://localhost:3000"
